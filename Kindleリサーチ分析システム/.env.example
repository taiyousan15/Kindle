# ===========================================
# Kindleリサーチ分析システム - 環境変数設定例
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ===========================================

# ===========================================
# DB / Redis（Docker起動時はそのままでOK）
# ===========================================
DB_USER=kindle_user
DB_PASSWORD=kindle_pass

# ===========================================
# LLM設定（AI分析エンジン）
# ===========================================

# プロバイダー選択: auto / ollama / openrouter / anthropic
# auto = Ollama(無料) → OpenRouter → Anthropic の順で自動選択（推奨）
LLM_PROVIDER=auto

# --- Ollama（ローカル・完全無料・推奨） ---
# 事前に以下を実行してください:
#   ollama pull qwen3:8b       ← テキスト分析用
#   ollama pull qwen3-vl:8b    ← 表紙画像分析用（ビジョン）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen3:8b
OLLAMA_VISION_MODEL=qwen3-vl:8b

# --- OpenRouter（クラウド・Ollamaのフォールバック） ---
# 取得先: https://openrouter.ai/
# ※ Ollamaが動いていれば基本不要
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_TEXT_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_VISION_MODEL=google/gemini-flash-1.5

# --- Anthropic直接（最終フォールバック・通常不要） ---
ANTHROPIC_API_KEY=

# ===========================================
# データ収集API
# ===========================================

# Keepa API（BSR履歴・書籍データ収集に必須 $19/月）
# 取得先: https://keepa.com/#!api
KEEPA_API_KEY=your_keepa_api_key_here

# Amazon PA-API（書籍詳細データ・任意）
# 取得先: https://affiliate.amazon.co.jp/
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# Helium10（キーワードボリューム精度向上・任意 $129/月）
# 取得先: https://www.helium10.com/
HELIUM10_API_KEY=

# MerchantWords（キーワードデータ追加・任意 $35/月）
# 取得先: https://www.merchantwords.com/
MERCHANTWORDS_API_KEY=

# ===========================================
# 検索・リサーチAPI（任意）
# ===========================================

# Tavily（AI検索）: https://tavily.com/
TAVILY_API_KEY=

# Brave Search: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# ===========================================
# アプリ設定
# ===========================================
DATABASE_URL=postgresql+asyncpg://kindle_user:kindle_pass@localhost:5432/kindle_research
REDIS_URL=redis://localhost:6379/0
